<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_dokumen" model="ir.module.category">
            <field name="name">Dokumen</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_dokumen_user" model="res.groups">
            <field name="name">Dokumen User</field>
            <field name="category_id" ref="module_category_dokumen"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_dokumen_manager" model="res.groups">
            <field name="name">Dokumen Manager</field>
            <field name="category_id" ref="module_category_dokumen"/>
            <field name="implied_ids" eval="[(4, ref('group_dokumen_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_dokumen_own_write" model="ir.rule">
            <field name="name">Dokumen Own Write</field>
            <field name="model_id" ref="model_dokumen_dokumen"/>
            <field name="groups" eval="[(4, ref('group_dokumen_user'))]"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
