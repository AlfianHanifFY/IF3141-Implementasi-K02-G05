<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dokumen_search" model="ir.ui.view">
        <field name="name">dokumen.dokumen.search</field>
        <field name="model">dokumen.dokumen</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <group expand="0" string="Group By">
                    <filter string="Prospek Klien" name="group_by_client" context="{'group_by': 'client_id'}"/>
                </group>
                <searchpanel>
                    <field name="client_id" icon="fa-users" enable_counters="1" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_dokumen_tree" model="ir.ui.view">
        <field name="name">dokumen.dokumen.tree</field>
        <field name="model">dokumen.dokumen</field>
        <field name="arch" type="xml">
            <tree string="Dokumen">
                <field name="name"/>
                <field name="type"/>
                <field name="file" filename="filename" widget="binary"/>
                <field name="client_id"/>
                <field name="create_date"/>
                <button name="unlink" type="object" icon="fa-trash" title="Hapus" confirm="Apakah Anda yakin ingin menghapus dokumen ini?"/>
            </tree>
        </field>
    </record>

    <record id="view_dokumen_form" model="ir.ui.view">
        <field name="name">dokumen.dokumen.form</field>
        <field name="model">dokumen.dokumen</field>
        <field name="arch" type="xml">
            <form string="Dokumen">
                <header>
                    <button name="unlink" type="object" string="Hapus" class="btn-secondary" confirm="Apakah Anda yakin ingin menghapus dokumen ini?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Kontrak Kerjasama"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type" readonly="id != False" required="1"/>
                            <field name="client_id" required="1"/>
                        </group>
                        <group>
                            <field name="filename" invisible="1"/>
                            <field name="file" filename="filename" widget="binary" required="type != 'invoice'"/>
                        </group>
                    </group>
                    
                    <group name="pks_details" string="PKS Information" invisible="type != 'pks'">
                        <group>
                            <field name="no_pks" required="type == 'pks'"/>
                            <field name="pks_id" string="Prospek PKS"/>
                        </group>
                        <group>
                            <field name="begin_date_pks"/>
                            <field name="end_date_pks"/>
                            <field name="value_pks" widget="monetary"/>
                        </group>
                    </group>

                    <group name="po_details" string="PO Information" invisible="type != 'po'">
                        <group>
                            <field name="no_po" required="type == 'po'"/>
                            <field name="po_id" string="Prospek PO"/>
                        </group>
                        <group>
                            <field name="begin_date_po"/>
                            <field name="end_date_po"/>
                            <field name="value_po" widget="monetary"/>
                        </group>
                        <group colspan="2">
                            <field name="description_po"/>
                        </group>
                    </group>

                    <group name="invoice_details" string="Invoice Information" invisible="type != 'invoice'">
                        <group colspan="2">
                            <button name="action_create_draft_invoice"
                                type="object"
                                string="Buat Draft Invoice"
                                class="btn-primary"/>
                        </group>
                        <group>
                            <field name="no_invoice" required="type == 'invoice'"/>
                            <field name="invoice_id" string="Prospek Invoice"/>
                            <field name="is_invoice_draft" readonly="1"/>
                        </group>
                        <group>
                            <field name="due_date_invoice"/>
                            <field name="value_invoice" widget="monetary"/>
                        </group>
                        <group colspan="2">
                            <field name="description_invoice"/>
                        </group>
                    </group>

                    <group name="kwitansi_details" string="Kwitansi Information" invisible="type != 'kwitansi'">
                        <group>
                            <field name="no_kwitansi" required="type == 'kwitansi'"/>
                            <field name="kwitansi_id" string="Invoice Terkait"/>
                        </group>
                        <group>
                            <field name="tgl_kwitansi"/>
                            <field name="value_kwitansi" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Deskripsi Umum" name="description">
                            <field name="description" placeholder="Catatan tambahan..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dokumen" model="ir.actions.act_window">
        <field name="name">Dokumen</field>
        <field name="res_model">dokumen.dokumen</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0), 
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_dokumen_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_dokumen_form')})]"/>
        <field name="search_view_id" ref="view_dokumen_search"/>
        <field name="context">{'search_default_group_by_client': 1}</field>
    </record>

    <menuitem id="menu_dokumen_root" name="Dokumen" sequence="20" web_icon="dokumen,static/description/icon.png" groups="dokumen.group_dokumen_user"/>
    <menuitem id="menu_dokumen_main" name="Dokumen" parent="menu_dokumen_root" sequence="10" action="action_dokumen" groups="dokumen.group_dokumen_user"/>
</odoo>
