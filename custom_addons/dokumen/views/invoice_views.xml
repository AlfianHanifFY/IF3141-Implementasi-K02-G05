<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dokumen_invoice_tree" model="ir.ui.view">
        <field name="name">dokumen.invoice.tree</field>
        <field name="model">dokumen.dokumen</field>
        <field name="arch" type="xml">
            <tree string="Invoice" create="0">
                <field name="name"/>
                <field name="no_invoice"/>
                <field name="invoice_id"/>
                <field name="due_date_invoice"/>
                <field name="value_invoice" widget="monetary"/>
                <field name="filename" invisible="1"/>
                <field name="file" filename="filename" widget="binary"/>
                <field name="client_id"/>
                <button name="unlink" type="object" icon="fa-trash" title="Hapus" confirm="Apakah Anda yakin ingin menghapus dokumen ini?"/>
            </tree>
        </field>
    </record>

    <record id="view_dokumen_invoice_form" model="ir.ui.view">
        <field name="name">dokumen.invoice.form</field>
        <field name="model">dokumen.dokumen</field>
        <field name="arch" type="xml">
            <form string="Invoice" create="0">
                <header>
                    <button name="unlink" type="object" string="Hapus" class="btn-secondary" confirm="Apakah Anda yakin ingin menghapus dokumen ini?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Invoice INV/001"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type" readonly="1"/>
                            <field name="client_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="filename" invisible="1"/>
                            <field name="file" filename="filename" widget="binary"/>
                        </group>
                    </group>
                    <group string="Invoice Information">
                        <group>
                            <field name="no_invoice"/>
                            <field name="invoice_id" string="Prospek Invoice"/>
                        </group>
                        <group>
                            <field name="due_date_invoice"/>
                            <field name="value_invoice" widget="monetary"/>
                        </group>
                        <group colspan="2">
                            <field name="description_invoice"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dokumen_invoice" model="ir.actions.act_window">
        <field name="name">Invoice</field>
        <field name="res_model">dokumen.dokumen</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type', '=', 'invoice')]</field>
        <field name="context">{'default_type': 'invoice', 'search_default_group_by_client': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_dokumen_invoice_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_dokumen_invoice_form')})]"/>
    </record>

    <menuitem id="menu_dokumen_invoice" name="Invoice" parent="menu_dokumen_root" sequence="40" action="action_dokumen_invoice" groups="dokumen.group_dokumen_user"/>
</odoo>
