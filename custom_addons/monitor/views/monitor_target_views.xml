<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root Menu -->
    <menuitem id="monitor_menu_root"
              name="Monitoring"
              sequence="1"
              groups="monitor.group_monitor_user"/>

    <!-- Action -->
    <record id="action_monitor_target" model="ir.actions.act_window">
        <field name="name">Target Monitoring</field>
        <field name="res_model">monitor.target</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Tree View -->
    <record id="view_monitor_target_tree" model="ir.ui.view">
        <field name="name">monitor.target.tree</field>
        <field name="model">monitor.target</field>
        <field name="arch" type="xml">
            <tree string="Target Monitoring">
                <field name="name"/>
                <field name="year"/>
                <field name="dokumen_id"/>
                <field name="total_target" sum="Total"/>
                <field name="total_realized" sum="Total"/>
                <field name="total_miss" sum="Total"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_monitor_target_form" model="ir.ui.view">
        <field name="name">monitor.target.form</field>
        <field name="model">monitor.target</field>
        <field name="arch" type="xml">
            <form string="Target Monitoring">
                <header>
                    <button name="action_generate_lines" string="Generate Monthly Lines" type="object" class="oe_highlight" invisible="line_ids != []"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nama Target"/>
                        <h1>
                            <field name="name" placeholder="Misal: Target PKS 2024 - Project ABC"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="year"/>
                            <field name="dokumen_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="prospect_id" readonly="1"/>
                        </group>
                    </group>
                    <group name="totals" col="3">
                        <field name="total_target" readonly="1"/>
                        <field name="total_realized" readonly="1"/>
                        <field name="total_miss" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Target Bulanan" name="monthly_targets">
                            <field name="line_ids">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="month" readonly="1" force_save="1"/>
                                    <field name="amount_target"/>
                                    <field name="amount_realized"/>
                                    <field name="amount_miss" readonly="1" force_save="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_monitor_target"
              name="Target Monitoring"
              parent="monitor_menu_root"
              action="action_monitor_target"
              sequence="10"
              groups="monitor.group_monitor_user"/>
</odoo>
