<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Tree View (Daftar Prospect) -->
    <record id="view_client_prospect_tree" model="ir.ui.view">
        <field name="name">client.prospect.tree</field>
        <field name="model">client.prospect</field>
        <field name="arch" type="xml">
            <tree string="Prospek Klien">
                <field name="company_name"/>
                <field name="project_name"/>
                <field name="am_id" string="AM"/>
                <field name="classification"/>
                <field name="probability"/>
                <field name="priority"/>
                <field name="status" widget="badge" decoration-info="status == 'new'" decoration-warning="status == 'progress'" decoration-success="status == 'won'" decoration-danger="status == 'loss'"/>
                <button name="unlink" type="object" icon="fa-trash" title="Hapus" confirm="Apakah Anda yakin ingin menghapus prospek ini?"/>
            </tree>
        </field>
    </record>

    <!-- 2. Form View (Detail Prospect) -->
    <record id="view_client_prospect_form" model="ir.ui.view">
        <field name="name">client.prospect.form</field>
        <field name="model">client.prospect</field>
        <field name="arch" type="xml">
            <form string="Prospek Klien">
                <header>
                    <button name="unlink" type="object" string="Hapus" class="btn-secondary" confirm="Apakah Anda yakin ingin menghapus prospek ini?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="company_name" string="Nama Klien"/>
                        <h1><field name="company_name" placeholder="Contoh: PT. ABC"/></h1>
                        <label for="company_address" string="Alamat Perusahaan"/>
                        <h2><field name="company_address" placeholder="Contoh: Jalan ABC"/></h2>
                        <label for="project_name" string="Nama Proyek"/>
                        <h2><field name="project_name" placeholder="Contoh: Project ABC"/></h2>
                    </div>
                    <group>
                        <group string="Informasi Utama">
                            <field name="am_id"/>
                            <field name="classification"/>
                            <field name="probability"/>
                            <field name="priority"/>
                            <field name="status"/>
                        </group>
                        <group string="Timeline &amp; Nilai">
                            <field name="currency_id" invisible="1"/>
                            <field name="contract_value"/>
                            <field name="start_date"/>
                            <field name="expected_end_date"/>
                            <field name="pic_email"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Deskripsi" name="description">
                            <field name="description" placeholder="Tambahkan deskripsi proyek di sini..."/>
                        </page>
                        <page string="Log Aktivitas" name="log_activities">
                            <field name="log_activity_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="am_id" readonly="1"/>
                                    <field name="activity_type"/>
                                    <field name="notes"/>
                                    <field name="status"/>
                                    <field name="result"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. Search View -->
    <record id="view_client_prospect_search" model="ir.ui.view">
        <field name="name">client.prospect.search</field>
        <field name="model">client.prospect</field>
        <field name="arch" type="xml">
            <search>
                <field name="company_name"/>
                <field name="project_name"/>
                <field name="am_id"/>
                <filter string="My Prospects" name="my_prospects" domain="[('am_id', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Account Manager" name="group_by_am" context="{'group_by': 'am_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 4. Action -->
    <record id="action_client_prospect" model="ir.actions.act_window">
        <field name="name">Prospek Klien</field>
        <field name="res_model">client.prospect</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada prospek. Klik 'New' untuk menambah.
            </p>
        </field>
    </record>
    <!-- 5. Menu Items -->
    <menuitem id="menu_client_prospect_root" name="Client Prospect" sequence="10" web_icon="client_prospect,static/description/icon.png" groups="client_prospect.group_log_am_user"/>
    <menuitem id="menu_client_prospect_main" name="Prospek" parent="menu_client_prospect_root" sequence="10" action="action_client_prospect" groups="client_prospect.group_log_am_user"/>
</odoo>
